rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Standard catch-all for Authenticated users
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Explicit public read for portfolio items
    match /projects/{id} { allow read: if true; }
    match /posts/{id} { allow read: if true; }
    match /certificates/{id} { allow read: if true; }
    match /skills/{id} { allow read: if true; }
    match /comments/{id} { allow read: if true; }
  }
}
